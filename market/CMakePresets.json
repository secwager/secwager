{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "default",
      "inherits": "vcpkg",
      "displayName": "Default",
      "description": "Ensure VCPKG_ROOT is set in your environment"
    }
  ]
}
